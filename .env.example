# Supabase 프로젝트 설정
# 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 프로젝트 이미지 베이스 URL (Supabase Storage 'project' 버킷)
# trailing slash(/) 포함
NEXT_PUBLIC_IMAGE_URL=https://xxxx.supabase.co/storage/v1/object/public/project/

# 배포 도메인 (SEO: sitemap, OG 메타데이터용)
# 로컬: http://localhost:3000 / 운영: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# MSW 모킹 (개발 시에만 enabled, 운영에서는 반드시 disabled)
NEXT_PUBLIC_API_MOCKING=disabled

# 어드민 이메일 (서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지)
# GitHub OAuth 로그인 시 매칭되는 이메일 주소
ADMIN_EMAIL=your-admin@email.com
